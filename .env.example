# Database
DATABASE_URL="postgresql://user:password@localhost:5432/jersey_journal"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_test_..."

# Nodemailer (Gmail OAuth2)
EMAIL_SERVER_USER="publisher@thejerseyjournal.news"
EMAIL_SERVER_PASSWORD="your-app-password"
EMAIL_FROM="The Jersey Journal <publisher@thejerseyjournal.news>"

# Or use SMTP directly
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="publisher@thejerseyjournal.news"
SMTP_PASSWORD="your-app-password"

# API Keys
OPENAI_API_KEY="sk-..."
GOOGLE_ANALYTICS_ID="G-..."

# Feature Flags
ENABLE_WIRE_CONTENT="false"
ENABLE_SOCIAL_POSTING="false"

# Vercel
VERCEL_URL="https://thejerseyjournal.news"
