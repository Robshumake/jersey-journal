// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          String    @default("editor") // admin, editor, viewer
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  articles Article[]

  @@map("users")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Article {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  excerpt         String
  content         String   @db.Text
  imageUrl        String?
  category        String   // news, legal-notices, obituaries, features
  featured        Boolean  @default(false)
  published       Boolean  @default(false)
  publishedAt     DateTime?
  scheduledFor    DateTime?
  authorId        String
  author          User     @relation(fields: [authorId], references: [id])
  views           Int      @default(0)
  shares          Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  relatedArticles RelatedArticle[] @relation("articleFrom")
  relatedTo       RelatedArticle[] @relation("articleTo")

  @@index([category])
  @@index([published])
  @@index([publishedAt])
  @@map("articles")
}

model RelatedArticle {
  id       String @id @default(cuid())
  fromId   String
  toId     String
  from     Article @relation("articleFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to       Article @relation("articleTo", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId])
  @@map("related_articles")
}

model LegalNotice {
  id               String   @id @default(cuid())
  businessName     String
  businessAddress  String
  noticeText       String   @db.Text
  publicationDate  DateTime
  issueNumber      String
  volumeNumber     String
  tier             String   // basic, standard, premium, attorney-annual
  stripePaymentId  String?  @unique
  status           String   @default("pending") // pending, published, archived
  submitterEmail   String
  submitterPhone   String
  affidavitPath    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  paymentRecord PaymentRecord?

  @@index([status])
  @@index([publicationDate])
  @@map("legal_notices")
}

model Obituary {
  id               String   @id @default(cuid())
  deceasedName     String
  deceasedAge      Int?
  deceasedPhoto    String?
  serviceDetails   String   @db.Text
  obituaryText     String   @db.Text
  tier             String   // basic, standard, premium
  stripePaymentId  String?  @unique
  status           String   @default("pending") // pending, published, archived
  submitterName    String
  submitterEmail   String
  submitterPhone   String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  paymentRecord PaymentRecord?

  @@index([status])
  @@index([deceasedName])
  @@map("obituaries")
}

model Feature {
  id               String   @id @default(cuid())
  fullName         String
  businessName     String?
  businessType     String
  description      String   @db.Text
  photo            String?
  website          String?
  email            String
  phone            String
  stripePaymentId  String?  @unique
  status           String   @default("pending") // pending, approved, featured, archived
  notes            String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  paymentRecord PaymentRecord?

  @@index([status])
  @@index([businessName])
  @@map("features")
}

model Subscription {
  id               String   @id @default(cuid())
  email            String   @unique
  stripeCustomerId String?
  stripeSubId      String?  @unique
  tier             String   @default("free") // free, premium
  status           String   @default("active") // active, canceled, past_due
  currentPeriodEnd DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status])
  @@map("subscriptions")
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("newsletter_subscribers")
}

model PaymentRecord {
  id               String   @id @default(cuid())
  amount           Float
  currency         String   @default("USD")
  type             String   // legal-notice, obituary, feature, subscription
  stripePaymentId  String   @unique
  status           String   @default("completed") // pending, completed, failed, refunded
  
  legalNoticeId    String?  @unique
  legalNotice      LegalNotice? @relation(fields: [legalNoticeId], references: [id], onDelete: Cascade)
  
  obituaryId       String?  @unique
  obituary         Obituary? @relation(fields: [obituaryId], references: [id], onDelete: Cascade)
  
  featureId        String?  @unique
  feature          Feature? @relation(fields: [featureId], references: [id], onDelete: Cascade)
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@map("payment_records")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
